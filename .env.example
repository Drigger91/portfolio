# Copy to .env.local and fill in.
# Groq (free/open) key powers the terminal's "ask me anything" feature.
# Get one at https://console.groq.com/keys — leave blank to disable AI gracefully.
GROQ_API_KEY=

# Optional model overrides (defaults shown):
# GROQ_CLASSIFY_MODEL=llama-3.1-8b-instant
# GROQ_ANSWER_MODEL=llama-3.3-70b-versatile
